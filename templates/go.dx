[meta]
name        = "go"
description = "Go development environment"
version     = "1.0.0"
author      = "dxon"

[base]
packages = ["curl", "git", "ca-certificates"]

[runtime]
env = { GOPATH = "/root/go" }

[[prompts]]
id       = "docker"
question = "Install Docker CLI tooling inside the container?"
options  = ["no", "yes"]
default  = "no"

[[steps]]
name  = "Install Go"
tools = ["go"]

[[steps]]
name  = "Install Docker"
tools = ["docker", "docker-compose"]
[steps.when]
docker = "yes"
